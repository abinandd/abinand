---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { personalInfo, projects } from "../utils/data.js";
import "../utils/projects.css";

const TAB_CATEGORIES = [
    { id: "all", label: "All" },
    { id: "websites", label: "Websites" },
    { id: "full stack", label: "Full Stack" },
];
---

<Layout title={`${personalInfo.name} — Projects`}>
    <div class="min-h-screen bg-[#0c0c0d]">
        <Navigation />

        <main class="max-w-screen-xl mx-auto px-5 pt-32 md:pt-40 pb-24">

            <!-- Page Header -->
            <div class="mb-12 text-center flex flex-col items-center">
                <h1 class="text-3xl font-semibold text-white tracking-tight">
                    All Projects
                </h1>
                <p class="mt-2 text-white/40 text-sm">A collection of things I've built.</p>
            </div>

            <!-- Filter Tabs -->
            <div class="flex items-center justify-center gap-2 mb-12 flex-wrap">
                {
                    TAB_CATEGORIES.map((cat, index) => (
                        <button
                            type="button"
                            class={`filter-tab px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 border ${
                                index === 0
                                    ? "bg-white text-black border-white active-tab"
                                    : "text-white/50 border-white/10 hover:text-white hover:border-white/30"
                            }`}
                            data-category={cat.id}
                        >
                            {cat.label}
                        </button>
                    ))
                }
            </div>

            <!-- Projects Grid — same design as homepage -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10 project-grid">
                {
                    projects.map((project) => (
                        <div
                            class="project-card flex flex-col gap-3"
                            data-category={project.category.toLowerCase()}
                        >
                            <!-- Image (clickable) -->
                            <a
                                href={`/projects/${project.slug}`}
                                class="group block w-full overflow-hidden"
                            >
                                <div class="w-full aspect-video overflow-hidden">
                                    <img
                                        src={project.image}
                                        alt={project.title}
                                        loading="lazy"
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                                    />
                                </div>
                            </a>

                            <!-- Text (separate from image) -->
                            <div class="flex flex-col gap-0.5">
                                <h3 class="text-base font-semibold text-white tracking-tight">
                                    {project.title}
                                </h3>
                            </div>
                        </div>
                    ))
                }
            </div>

        </main>

        <Footer />
    </div>
</Layout>

<script>
    import { initProjectFilter } from "../utils/projectsFilter.ts";
    document.addEventListener("DOMContentLoaded", () => {
        initProjectFilter();
    });
</script>
