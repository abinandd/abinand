---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { personalInfo, projects } from "../utils/data.js";

// Define the available categories based on user feedback
const TAB_CATEGORIES = [
    { id: "all", label: "All projects" },
    { id: "websites", label: "Websites" },
    { id: "full stack", label: "Full Stack" },
];
---

<Layout title={`${personalInfo.name} - Projects`}>
    <div class="page-wrapper bg-gray-50 min-h-screen text-gray-900">
        <Navigation />

        <div class="max-w-screen-xl mx-auto px-5 py-20 text-center">
            <h1
                class="text-6xl md:text-8xl font-semibold tracking-tight text-gray-900 mb-10 md:mb-16"
            >
                Recent Projects
            </h1>

            <!-- Filter Tabs directly inspired by the mock -->
            <div
                class="flex flex-wrap items-center justify-center gap-2 p-2 bg-white rounded-full mx-auto w-fit mb-12 md:mb-20 border border-gray-200 shadow-sm"
            >
                {
                    TAB_CATEGORIES.map((cat, index) => (
                        <button
                            type="button"
                            class={`filter-tab px-6 py-2.5 rounded-full font-medium transition-colors text-sm md:text-base ${
                                index === 0
                                    ? "bg-black text-white active-tab"
                                    : "text-gray-500 hover:text-black"
                            }`}
                            data-category={cat.id}
                        >
                            {cat.label}
                        </button>
                    ))
                }
            </div>

            <!-- Projects Grid directly inspired by the large rounded boxes in the mock -->
            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10 project-grid"
            >
                {
                    projects.map((project) => (
                        <a
                            href={project.link}
                            target="_blank"
                            class="project-card block w-full group overflow-hidden"
                            data-category={project.category.toLowerCase()}
                        >
                            <div class="bg-white border border-gray-200 shadow-sm p-2 md:p-3 rounded-[2.5rem] w-full aspect-[4/3] relative">
                                <img
                                    src={project.image}
                                    alt={project.title}
                                    loading="lazy"
                                    class="w-full h-full object-cover rounded-[2rem] group-hover:scale-105 transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)]"
                                />
                                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col items-center justify-center rounded-[2rem] m-2 md:m-3">
                                    <span class="text-white text-2xl md:text-4xl font-semibold tracking-tight translate-y-4 group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.25,1,0.5,1)]">
                                        {project.title}
                                    </span>
                                    <span class="text-gray-300 mt-2 text-sm md:text-base opacity-0 group-hover:opacity-100 transition-opacity delay-100 duration-500">
                                        {project.category}
                                    </span>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>

        <Footer />
    </div>
</Layout>

<script>
    // Client-side filtering logic
    const tabs = document.querySelectorAll(".filter-tab");
    const cards = document.querySelectorAll<HTMLElement>(".project-card");

    tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
            // 1. Reset all tabs to inactive styles
            tabs.forEach((t) => {
                t.classList.remove("bg-black", "text-white", "active-tab");
                t.classList.add("text-gray-500");
            });

            // 2. Set the clicked tab as active
            tab.classList.remove("text-gray-500");
            tab.classList.add("bg-black", "text-white", "active-tab");

            // 3. Filter the cards
            const targetCategory = tab.getAttribute("data-category");

            cards.forEach((card) => {
                // We use inner element styles to properly trigger animation rather than just display: none class
                const htmlCard = card;
                const cardCategory = htmlCard.getAttribute("data-category");

                if (
                    targetCategory === "all" ||
                    cardCategory === targetCategory
                ) {
                    htmlCard.style.display = "block";
                    // Force a repaint so animation triggers from scratch
                    htmlCard.style.animation = "none";
                    htmlCard.offsetHeight; /* trigger reflow */
                    htmlCard.style.animation =
                        "fadeInUp 0.6s cubic-bezier(0.25, 1, 0.5, 1) forwards";
                } else {
                    htmlCard.style.display = "none";
                }
            });
        });
    });
</script>

<style>
    /* Custom pop-in animation for layout shifts */
    @keyframes fadeInUp {
        0% {
            opacity: 0;
            transform: translateY(20px) scale(0.98);
        }
        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
</style>
