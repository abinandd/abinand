---
import { personalInfo } from "../utils/data.js";
/**
 * Navigation Component - Premium White Floating Pill (Expandable)
 */
---

<header
  class="fixed top-8 left-0 right-0 z-[120] flex justify-center px-4 pointer-events-none"
>
  <nav
    id="pill-nav"
    class="pointer-events-auto bg-white/95 backdrop-blur-3xl rounded-full shadow-[0_15px_40px_rgba(0,0,0,0.3)] border border-black/5 flex items-center p-1.5 pl-3 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] min-w-[280px] group-[.is-expanded]/nav:min-w-[320px] justify-between group/nav"
  >
    <!-- Left: Profile -->
    <a href="/" class="flex items-center gap-3 shrink-0 group/avatar">
      <div
        class="w-9 h-9 rounded-full overflow-hidden bg-white/10 ring-2 ring-black/5 transition-transform group-hover/avatar:scale-110"
      >
        <img
          src="https://api.dicebear.com/7.x/avataaars/svg?seed=Abhinand&backgroundColor=b6e3f4"
          alt={personalInfo.name}
          class="w-full h-full object-cover"
        />
      </div>
      <span
        class="!text-black !font-bold !text-[14px] tracking-tight hidden sm:block"
      >
        {personalInfo.name}
      </span>
    </a>

    <!-- Middle Content: (Visible only when expanded) -->
    <div
      class="flex items-center overflow-hidden transition-all duration-500 ease-in-out max-w-0 opacity-0 group-[.is-expanded]/nav:max-w-[700px] group-[.is-expanded]/nav:opacity-100 group-[.is-expanded]/nav:mx-4"
    >
      <div class="flex items-center gap-2 pl-4 border-l border-black/5">
        <a
          href="#about"
          class="!no-underline px-3 py-1.5 !text-[13px] font-bold !text-black/60 hover:!text-black transition-colors rounded-full hover:bg-black/5 !tracking-[0.02em]"
          >About</a
        >
        <a
          href="#works"
          class="!no-underline px-3 py-1.5 !text-[13px] font-bold !text-black/60 hover:!text-black transition-colors rounded-full hover:bg-black/5 !tracking-[0.02em]"
          >Works</a
        >
        <a
          href="#services"
          class="!no-underline px-3 py-1.5 !text-[13px] font-bold !text-black/60 hover:!text-black transition-colors rounded-full hover:bg-black/5 !tracking-[0.02em]"
          >Services</a
        >
        <a
          href="#blog"
          class="!no-underline px-3 py-1.5 !text-[13px] font-bold !text-black/60 hover:!text-black transition-colors rounded-full hover:bg-black/5 !tracking-[0.02em] hidden md:block"
          >Blog</a
        >
      </div>
    </div>

    <!-- Right: Expansion Trigger -->
    <button
      id="menu-toggle"
      class="w-9 h-9 bg-black rounded-full flex items-center justify-center transition-all duration-500 hover:scale-105 active:scale-95 shrink-0 ml-4 group-hover/nav:bg-[#222]"
      aria-label="Toggle Menu"
    >
      <div class="relative w-4 h-4 flex items-center justify-center">
        <span
          class="absolute h-[1.5px] w-4 bg-white rounded-full transition-all duration-500 group-[.is-expanded]/nav:rotate-45 -translate-y-1.5 group-[.is-expanded]/nav:translate-y-0"
        ></span>
        <span
          class="absolute h-[1.5px] w-4 bg-white rounded-full transition-all duration-500 group-[.is-expanded]/nav:opacity-0 group-[.is-expanded]/nav:translate-x-4"
        ></span>
        <span
          class="absolute h-[1.5px] w-4 bg-white rounded-full transition-all duration-500 group-[.is-expanded]/nav:-rotate-45 translate-y-1.5 group-[.is-expanded]/nav:translate-y-0"
        ></span>
      </div>
    </button>
  </nav>
</header>

<div
  id="nav-backdrop"
  class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[100] opacity-0 pointer-events-none transition-opacity duration-700"
>
</div>

<script>
  const pill = document.querySelector("#pill-nav");
  const toggle = document.querySelector("#menu-toggle");
  const backdrop = document.querySelector("#nav-backdrop");
  let isExpanded = false;

  const update = (state: boolean) => {
    isExpanded = state;
    if (pill) pill.classList.toggle("is-expanded", isExpanded);
    if (backdrop) {
      backdrop.classList.toggle("opacity-100", isExpanded);
      backdrop.classList.toggle("pointer-events-auto", isExpanded);
    }
  };

  if (toggle && pill && backdrop) {
    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      update(!isExpanded);
    });

    document.addEventListener("click", (e) => {
      if (isExpanded && !pill.contains(e.target as Node)) update(false);
    });

    pill
      .querySelectorAll("a")
      .forEach((l) => l.addEventListener("click", () => update(false)));
  }
</script>
