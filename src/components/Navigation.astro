---
import { personalInfo } from "../utils/data.js";
---

<header
  class="fixed top-8 left-0 right-0 z-[100] flex justify-center px-4 pointer-events-none"
>
  <nav
    id="pill-nav"
    class="pointer-events-auto bg-white/90 backdrop-blur-md rounded-full shadow-lg border border-gray-200/50 flex items-center p-1.5 pl-3 transition-all duration-500 ease-in-out ring-1 ring-black/5 min-w-[300px] justify-between max-w-fit hover:shadow-xl group/nav"
  >
    <!-- Left: Profile -->
    <a href="/" class="flex items-center gap-3 group shrink-0">
      <div
        class="w-9 h-9 rounded-full overflow-hidden bg-gray-100 border border-gray-200 transition-transform duration-500 group-hover:scale-105"
      >
        <img
          src="https://api.dicebear.com/7.x/avataaars/svg?seed=Abhinand&backgroundColor=b6e3f4"
          alt={personalInfo.name}
          class="w-full h-full object-cover"
        />
      </div>
      <span
        class="text-black font-semibold text-sm tracking-tight hidden sm:block"
      >
        {personalInfo.name}
      </span>
    </a>

    <!-- Middle: Links -->
    <div
      class="flex items-center overflow-hidden transition-all duration-500 ease-in-out max-w-0 opacity-0 group-[.is-expanded]/nav:max-w-[800px] group-[.is-expanded]/nav:opacity-100"
    >
      <div class="flex items-center gap-1 ml-4 pl-4 border-l border-gray-100">
        {
          [
            { label: "Home", href: "/" },
            { label: "Projects", href: "/projects" },
            { label: "Services", href: "/services" },
            { label: "About", href: "/about" },
            { label: "Blog", href: "/blogs" },
          ].map((link) => (
            <a
              href={link.href}
              class="px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-black hover:bg-gray-50 rounded-full transition-colors whitespace-nowrap"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="/shop"
          class="px-4 py-1.5 bg-black text-white text-[10px] font-bold rounded-full hover:bg-gray-800 transition-all uppercase tracking-wider ml-2"
          >Shop</a
        >
      </div>
    </div>

    <!-- Right: Menu -->
    <button
      id="menu-toggle"
      class="w-9 h-9 bg-black rounded-full flex flex-col items-center justify-center gap-[3px] transition-all duration-500 hover:bg-gray-900 active:scale-90 shrink-0"
      aria-label="Toggle Menu"
    >
      <div
        class="w-4 h-[1.2px] bg-white rounded-full transition-all duration-500 group-[.is-expanded]/nav:rotate-45 group-[.is-expanded]/nav:translate-y-[2px]"
      >
      </div>
      <div
        class="w-4 h-[1.2px] bg-white rounded-full transition-all duration-500 group-[.is-expanded]/nav:-rotate-45 group-[.is-expanded]/nav:-translate-y-[2px]"
      >
      </div>
    </button>
  </nav>

  <div
    id="nav-backdrop"
    class="fixed inset-0 bg-black/5 backdrop-blur-[1px] z-[-1] opacity-0 pointer-events-none transition-opacity duration-500"
  >
  </div>
</header>

<script>
  const pill = document.querySelector("#pill-nav");
  const toggle = document.querySelector("#menu-toggle");
  const backdrop = document.querySelector("#nav-backdrop");
  let isExpanded = false;

  const update = (state) => {
    isExpanded = state;
    pill.classList.toggle("is-expanded", isExpanded);
    backdrop.classList.toggle("opacity-100", isExpanded);
    backdrop.classList.toggle("pointer-events-auto", isExpanded);
  };

  if (toggle && pill && backdrop) {
    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      update(!isExpanded);
    });
    document.addEventListener("click", (e) => {
      if (isExpanded && !pill.contains(e.target)) update(false);
    });
    pill
      .querySelectorAll("a")
      .forEach((l) => l.addEventListener("click", () => update(false)));
  }
</script>
