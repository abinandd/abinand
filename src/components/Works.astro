---
import { projects } from "../utils/data.js";
---

<section class="w-full px-5 py-12 md:py-16" id="works">
  <div class="max-w-screen-xl mx-auto w-full">

    <!-- Section Header -->
    <h2 class="text-3xl font-semibold text-white tracking-tight mb-10">
      Recent Projects
    </h2>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
      {
        projects.slice(0, 3).map((project) => (
          <div class={`${project.visibilityClasses} flex flex-col gap-3`}>
            <!-- Image -->
            <a
              href={`/projects/${project.slug}`}
              class="group block w-full overflow-hidden"
            >
              <div class="w-full aspect-video overflow-hidden">
                <img
                  src={project.image}
                  alt={project.title}
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                />
              </div>
            </a>

            <!-- Text -->
            <div class="flex flex-col gap-0.5">
              <h3 class="text-base font-semibold text-white tracking-tight">
                {project.title}
              </h3>
              <span class="text-sm text-white/40">{project.category}</span>
            </div>
          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="mt-14 flex justify-center">
      <a
        href="/projects"
        class="group inline-flex items-center gap-2 bg-white px-6 py-2.5 rounded-full font-semibold text-sm transition-all duration-300 hover:bg-white/90 hover:scale-[1.02] active:scale-95"
        style="color: black !important;"
      >
        <span style="color: black !important;">Explore more</span>
        <svg
          class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5"
          viewBox="0 0 12 12"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M8.78166 5.33312L5.20566 1.75712L6.14833 0.814453L11.3337 5.99979L6.14833 11.1851L5.20566 10.2425L8.78166 6.66645H0.666992V5.33312H8.78166Z"
            fill="currentColor"></path>
        </svg>
      </a>
    </div>

  </div>
</section>
