---
import { projects, personalInfo } from "../utils/data.js";
---

<section class="w-full px-5 py-32 md:py-48 bg-transparent" id="works">
  <div class="max-w-screen-xl mx-auto w-full">
    <!-- Works Header -->
    <div class="mb-16 md:mb-24">
      <h2 class="text-3xl font-bold text-white tracking-tight">
        Recent Projects
      </h2>
    </div>

    <!-- Works Grid -->
    <!-- Works Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {
        projects.map((project) => (
          <a
            href={project.link}
            target="_blank"
            class={`${project.visibilityClasses} group flex flex-col gap-4`}
          >
            <div class="aspect-[4/3] w-full overflow-hidden rounded-3xl bg-white/5 border border-white/10">
              <img
                src={project.image}
                alt={project.title}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700 ease-out"
              />
            </div>
            <div class="flex flex-col gap-1 px-1">
              <h3 class="text-xl font-bold text-white tracking-tight">
                {project.title}
              </h3>
              <p class="text-sm font-medium text-white/50 tracking-wide uppercase">
                {project.category}
              </p>
            </div>
          </a>
        ))
      }
    </div>
    <!-- View All Button -->
    <div class="mt-16 flex justify-center">
      <a
        href={personalInfo.github}
        target="_blank"
        class="group flex items-center justify-center space-x-2 bg-black text-white px-8 py-4 rounded-full font-medium text-lg hover:bg-gray-800 transition-colors"
      >
        <span>View My GitHub</span>
        <svg
          class="w-5 h-5 opacity-70 group-hover:opacity-100 transition-opacity"
          viewBox="0 0 12 12"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M8.78166 5.33312L5.20566 1.75712L6.14833 0.814453L11.3337 5.99979L6.14833 11.1851L5.20566 10.2425L8.78166 6.66645H0.666992V5.33312H8.78166Z"
            fill="currentColor"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
