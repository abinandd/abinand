---
import { projects, personalInfo } from "../utils/data.js";
---

<section class="w-full px-5 py-32 md:py-48 bg-white" id="works">
  <div class="max-w-screen-xl mx-auto w-full">
    <!-- Introductory / Mission Text -->
    <div class="max-w-5xl mx-auto text-left mb-32 md:mb-48">
      <p
        id="simple-reveal-text"
        class="text-4xl md:text-5xl lg:text-5xl font-medium leading-[1.3] text-black tracking-tight opacity-100"
      >
        Developer focused on strong fundamentals, scalable solutions, and
        writing clean, efficient code. I enjoy turning complex requirements into
        simple, reliable software while continuously improving code quality.
      </p>
    </div>

    <script>
      import { initSimpleReveal } from "../utils/animations.js";

      document.addEventListener("DOMContentLoaded", () => {
        initSimpleReveal("#simple-reveal-text");
      });
    </script>

    <!-- Works Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      {
        projects.map((project) => (
          <a
            href={project.link}
            target="_blank"
            class={project.visibilityClasses}
          >
            <img
              src={project.image}
              alt={project.title}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </a>
        ))
      }
    </div>

    <!-- View All Button -->
    <div class="mt-16 flex justify-center">
      <a
        href={personalInfo.github}
        target="_blank"
        class="group flex items-center justify-center space-x-2 bg-black text-white px-8 py-4 rounded-full font-medium text-lg hover:bg-gray-800 transition-colors"
      >
        <span>View My GitHub</span>
        <svg
          class="w-5 h-5 opacity-70 group-hover:opacity-100 transition-opacity"
          viewBox="0 0 12 12"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M8.78166 5.33312L5.20566 1.75712L6.14833 0.814453L11.3337 5.99979L6.14833 11.1851L5.20566 10.2425L8.78166 6.66645H0.666992V5.33312H8.78166Z"
            fill="currentColor"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
