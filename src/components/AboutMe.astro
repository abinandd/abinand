---
import LogoLoop from "./LogoLoop.astro";
/**
 * AboutMe Component
 * Combines the mission statement with the technology loop.
 */
---

<section
    class="w-full px-5 py-32 md:py-48 bg-transparent overflow-hidden"
    id="about"
>
    <div class="max-w-screen-xl mx-auto w-full">
        <!-- Bio Text -->
        <div class="max-w-5xl mx-auto text-left mb-16 md:mb-24">
            <p
                id="about-reveal-text"
                class="text-4xl md:text-5xl lg:text-5xl font-medium leading-[1.3] text-white tracking-tight"
            >
                Developer focused on strong fundamentals, scalable solutions,
                and writing clean, efficient code. I enjoy turning complex
                requirements into simple, reliable software while continuously
                improving code quality.
            </p>
        </div>

        <!-- Technology Stack Loop -->
        <div class="pt-16">
            <LogoLoop />
        </div>
    </div>
</section>

<script>
    import { initSimpleReveal } from "../utils/animations.js";

    document.addEventListener("DOMContentLoaded", () => {
        initSimpleReveal("#about-reveal-text");
    });
</script>
