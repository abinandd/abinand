---
import { personalInfo } from "../utils/data.js";
---

<div
  class="w-full px-5 py-32 md:py-52 lg:py-72 flex justify-center bg-gray-50 min-h-[60vh] items-center"
>
  <div class="max-w-screen-xl mx-auto flex flex-col items-center text-center">
    <div class="w-full max-w-5xl">
      <h1
        id="hero-heading"
        class="split-text text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-bold tracking-tighter text-gray-900 leading-[0.95] opacity-0"
      >
        {personalInfo.headline}
      </h1>
    </div>
  </div>
</div>

<script>
  import { initSplitText } from "../utils/animations.js";

  // High-performance character reveal animation
  document.addEventListener("DOMContentLoaded", () => {
    initSplitText("#hero-heading");
  });
</script>
